# Copy this file to `.env` (in the same n8n/ directory) and fill in real values.
# `docker compose up` will pick it up automatically.

# ── Groq (LLM scoring, free tier — Llama 3.3 70B) ────────────────────────
# Setup (2 min):
#   1. Go to https://console.groq.com/keys → sign in (Google/GitHub) → "Create API Key"
#   2. Copy the key (starts with  gsk_... )
# Free tier: ~30 req/min, ~14,400 req/day — well within our daily run usage.
GROQ_API_KEY=

# ── Telegram (delivery) ──────────────────────────────────────────────────
# Setup (2 min):
#   1. On Telegram, search "@BotFather" → start chat → send  /newbot
#   2. Pick a name (e.g. "PM Job Hunter") and a username ending in "bot"
#      (e.g. "pm_job_hunter_bot")
#   3. BotFather replies with a token like  123456:ABC-DEF...  → that's TELEGRAM_BOT_TOKEN
#   4. Search for your bot in Telegram → start chat → send any message (e.g. "hi")
#   5. Open this URL in a browser (paste your token in place of <TOKEN>):
#        https://api.telegram.org/bot<TOKEN>/getUpdates
#      Find  "chat":{"id":<NUMBER> in the JSON  →  that's TELEGRAM_CHAT_ID
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
